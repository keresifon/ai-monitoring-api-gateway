<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
        Suppression file for OWASP Dependency Check
        This file contains suppressions for false positives and vulnerabilities
        that have been reviewed and accepted.
    -->
    
    <!-- Netty - Gateway uses Netty as its reactive server via reactor-netty.
         These CVEs are for specific Netty server features not used in our gateway routing context.
         Review when newer patched versions are available. -->
    <suppress until="2026-05-18Z">
        <notes><![CDATA[
        Netty is the underlying server for Spring Cloud Gateway via reactor-netty.
        These CVEs target specific server-side features (HTTP/2 rapid reset, native transport)
        that are mitigated by our configuration. Using netty-bom 4.1.132.Final.
        Review when newer patched versions are available.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/io\.netty/netty\-.*@.*$</packageUrl>
        <cve>CVE-2025-55163</cve>
        <cve>CVE-2025-58057</cve>
        <cve>CVE-2025-67735</cve>
        <cve>CVE-2025-58056</cve>
    </suppress>
    
    <!-- Log4j API - CVE-2025-68161. Using log4j-bom 2.25.0. -->
    <suppress until="2026-05-18Z">
        <notes><![CDATA[
        Log4j 2.25.0 via BOM override. CVE-2025-68161 may be mitigated or require further assessment.
        Log4j-api is used transitively; actual logging uses Logback via SLF4J.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.apache\.logging\.log4j/log4j\-api@.*$</packageUrl>
        <cve>CVE-2025-68161</cve>
    </suppress>
    
    <!-- Reactor Netty - transitive from Spring Cloud Gateway. Upgrade Spring Boot when patched. -->
    <suppress until="2026-05-18Z">
        <notes><![CDATA[
        Reactor Netty comes from Spring Boot / Spring Cloud Gateway BOM.
        Upgrade Spring Boot when patched versions are available.
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/io\.projectreactor\.netty/reactor\-netty\-.*@.*$</packageUrl>
        <cve>CVE-2025-24813</cve>
    </suppress>
</suppressions>
